<%= render "layouts/htmldoc" do %>
  <% unless turbo_native_app? %>
    <%= render "layouts/desktop_sidebar" %>

    <%= render "layouts/mobile_bottom_nav" %>
  <% end %>

  <div class="<%= turbo_native_app? ? '' : 'lg:pl-64' %>">
    <main class="p-8 text-gray-900 dark:text-white">
      <%= yield %>
    </main>
    <% unless turbo_native_app? %>
      <div class="lg:hidden h-16"></div>
    <% end %>
  </div>
<% end %>
