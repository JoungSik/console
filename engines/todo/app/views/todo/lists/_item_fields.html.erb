<div class="item-fields border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 rounded-md p-4 space-y-3" data-nested-form-target="item">
  <%= form.hidden_field :id %>

  <div class="flex items-center gap-3">
    <label class="flex-shrink-0 cursor-pointer relative">
      <span class="sr-only">완료 여부</span>
      <%= form.check_box :completed, class: "peer sr-only" %>
      <div class="w-5 h-5 border-2 border-gray-300 dark:border-gray-600 rounded hover:border-green-400 dark:hover:border-green-300 transition-colors duration-200 peer-checked:bg-green-500 peer-checked:border-green-500"></div>
      <svg class="w-3 h-3 text-white absolute top-1 left-1 hidden peer-checked:block" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"></path>
      </svg>
    </label>
    <div class="flex-1">
      <%= form.label :title, "제목", class: "sr-only" %>
      <%= form.text_field :title, placeholder: "할 일 제목을 입력하세요", class: "w-full border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
    </div>
  </div>

  <div>
    <%= form.label :due_date, "마감일", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= form.date_field :due_date, class: "w-full border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
  </div>

  <div data-controller="recurrence">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
      <div>
        <%= form.label :recurrence, "반복", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= form.select :recurrence,
              options_for_select([["반복 안 함", ""]] + Todo::Item::RECURRENCE_LABELS.map { |k, v| [v, k] }, form.object&.recurrence),
              {},
              class: "w-full border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent",
              data: { recurrence_target: "select", action: "change->recurrence#toggle" } %>
      </div>

      <div data-recurrence-target="endsOnField" class="<%= 'hidden' unless form.object&.recurrence.present? %>">
        <%= form.label :recurrence_ends_on, "반복 종료일", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
        <%= form.date_field :recurrence_ends_on, class: "w-full border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
      </div>
    </div>
  </div>

  <div>
    <%= form.label :url, "링크", class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" %>
    <%= form.url_field :url, placeholder: "https://example.com (선택사항)",
        class: "w-full border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-gray-900 dark:text-white placeholder-gray-500 dark:placeholder-gray-400 rounded-md px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent" %>
  </div>

  <div class="flex justify-end">
    <%= form.hidden_field :_destroy, value: "0", data: { nested_form_target: "destroyField" } %>
    <%= link_to "할 일 삭제", "#", data: { action: "click->nested-form#remove_association" }, class: "text-sm text-red-600 dark:text-red-400 hover:text-red-800 dark:hover:text-red-300" %>
  </div>
</div>
