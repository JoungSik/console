<article id="<%= dom_id post %>" class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg shadow-sm">
  <div class="p-4 sm:p-5">
    <div class="flex items-start justify-between gap-3 mb-3">
      <%= link_to posts.post_path(post), class: "min-w-0 text-sm text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-300 transition-colors duration-200" do %>
        <%= post.created_at.strftime("%Y-%m-%d %H:%M") %>
      <% end %>

      <div class="flex flex-shrink-0 items-center gap-2">
        <%= link_to posts.edit_post_path(post), class: "inline-flex items-center justify-center p-1.5 rounded-md text-gray-500 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors duration-200", aria: { label: "포스트 수정" } do %>
          <%= lucide_icon "pencil", class: "w-4 h-4" %>
        <% end %>
        <%= button_to posts.post_path(post), method: :delete, class: "inline-flex items-center justify-center p-1.5 rounded-md text-red-600 dark:text-red-400 hover:bg-red-50 dark:hover:bg-red-900 transition-colors duration-200", data: { turbo_confirm: "정말 삭제하시겠습니까?" }, aria: { label: "포스트 삭제" } do %>
          <%= lucide_icon "trash-2", class: "w-4 h-4" %>
        <% end %>
      </div>
    </div>

    <p class="whitespace-pre-wrap break-words text-gray-900 dark:text-white"><%= post.body %></p>
  </div>
</article>
